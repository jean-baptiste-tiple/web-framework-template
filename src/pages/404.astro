---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';

const meta = { title: 'Page introuvable', description: 'Erreur 404', seo: { noindex: true } };
---

<BaseLayout meta={meta} type="website">
  <Container class="py-24 text-center">
    <h1 class="text-5xl font-bold">404</h1>
    <p class="mt-3 text-[var(--color-muted)]">Cette page n’existe pas.</p>
    <div class="mt-8"><Button href="/">Retour à l’accueil</Button></div>
  </Container>
</BaseLayout>
