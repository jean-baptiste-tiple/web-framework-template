---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import ContactForm from '@/components/ui/ContactForm.astro';

const meta = {
  title: 'Contact',
  description: 'Formulaire de contact.',
};
---

<BaseLayout meta={meta} type="page">
  <Section>
    <Container prose>
      <h1 class="mb-2 text-3xl font-bold tracking-tight">Contact</h1>
      <p class="mb-8 text-[var(--color-muted)]">
        Formulaire statique posté vers un service tiers. Configurer
        <code>PUBLIC_FORM_ENDPOINT</code> dans <code>.env</code>.
      </p>
      <ContactForm />
    </Container>
  </Section>
</BaseLayout>
